@using Microsoft.AspNetCore.Mvc.TagHelpers
@using SFA.DAS.Admin.Roatp.Domain.Models
@using SFA.DAS.Admin.Roatp.Web.Infrastructure
@model SFA.DAS.Admin.Roatp.Web.Models.AddProviderConfirmationViewModel
@{
    ViewData["Title"] = "New training provider added";
}

<div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">

        <div class="govuk-panel govuk-panel--confirmation govuk-!-margin-bottom-7">
            <h1 class="govuk-panel__title">
                New training provider added
            </h1>
        </div>
        <p class="govuk-body">
            You have successfully added <strong>@Model.LegalName</strong> to APAR.
        </p>
        <p class="govuk-body">
            Go <a class="govuk-link" href="@Model.DashboardLink">back to the dashboard</a>,
        </p>
    </div>
</div>